<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1A1A1A"
    android:paddingVertical="6dp"
    android:paddingHorizontal="6dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavGraph"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/nav_graph"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        app:iconPadding="0dp"
        android:backgroundTint="#232323"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavStatistics"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/nav_statistics"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textColor="#888888"
        app:iconPadding="0dp"
        android:backgroundTint="#232323"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavCarbInsulin"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/nav_carb_insulin"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textColor="#888888"
        app:iconPadding="0dp"
        android:backgroundTint="#232323"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavTools"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/nav_tools"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textColor="#888888"
        app:iconPadding="0dp"
        android:backgroundTint="#232323"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavSettings"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/nav_settings"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textColor="#888888"
        app:iconPadding="0dp"
        android:backgroundTint="#232323"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

</LinearLayout>
